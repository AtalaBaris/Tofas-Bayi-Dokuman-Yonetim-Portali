{
  // Bağlantı ve çalışma ayarları. Gizli anahtarları production'da secret/env ile verin.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Lokal Postgres: Port=5432 | Docker Compose: Port=5433
    "DefaultConnection": "Host=localhost;Port=5432;Database=BayiPortalDb;Username=bayi;Password=bayi123"
  },
  "FileStorage": {
    // Yüklenen dosyaların disk kökü (unique StoredFileName ile)
    "RootPath": "uploads",
    "MaxFileSizeBytes": 26214400
  },
  "Jwt": {
    "Issuer": "BayiPortal",
    "Audience": "BayiPortal",
    "Key": "CHANGE_ME_DEV_ONLY_SUPER_SECRET_KEY_32+",
    "ExpireMinutes": 120
  }
}
